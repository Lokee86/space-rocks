{
  cd /mnt/d/\!bin/space-rocks
  SECRET_FILE="$(grep -rlE '^(export[[:space:]]+)?DISCORD_CLIENT_ID=' .secrets 2>/dev/null | head -n 1)"
  echo "SECRET_FILE=$SECRET_FILE"
  SECRET_FILE=".secrets/api-server.env"

  if [ -f "$SECRET_FILE" ]; then
    watch_file "$SECRET_FILE"
    set -a
    source "$SECRET_FILE"
    set +a
    echo "Loaded API secrets from $SECRET_FILE"
  else
    echo "Missing $SECRET_FILE"
  fi
}

export SPACE_ROCKS_ROOT="${SPACE_ROCKS_ROOT:-/mnt/d/!bin/space-rocks}"
export PATH="$SPACE_ROCKS_ROOT/tools/bin:$PATH"

data-sync() {
        (
                cd "$SPACE_ROCKS_ROOT" || return
                python3 tools/data_sync/main.py "$@"
        )
}
export SPACE_ROCKS_ROOT="${SPACE_ROCKS_ROOT:-/mnt/d/!bin/space-rocks}"
export PATH="$SPACE_ROCKS_ROOT/tools/bin:$PATH"

SECRET_FILE="$SPACE_ROCKS_ROOT/.secrets/api-server.env"

if [ -f "$SECRET_FILE" ]; then
  watch_file "$SECRET_FILE"
  set -a
  source "$SECRET_FILE"
  set +a
  echo "Loaded API secrets from $SECRET_FILE"
else
  echo "Missing $SECRET_FILE"
fi

data-sync() {
  (
    cd "$SPACE_ROCKS_ROOT" || return
    python3 tools/data_sync/main.py "$@"
  )
}
