---
import { getCollection } from "astro:content";
import HomepageClientMount from '../../components/HomepageClientMount';
import '../../components/plasmic/plasmic__default_style.css';
import '../../components/plasmic/space_rocks_devlog/plasmic.css';

export async function getStaticPaths() {
	const devlogEntries = await getCollection("devlog");

	return devlogEntries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const homepageContent = {
	...entry.data,
	body: entry.body ?? "",
};

const shareImageUrl = new URL("/assets/ui/thumbnail.png", Astro.site).toString();
const shareUrl = new URL(`/devlog/${entry.id}/`, Astro.site).toString();
const shareTitle = entry.data.title;
const shareDescription = entry.data.summary;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/assets/ui/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#00e5ff" />
		<meta name="generator" content={Astro.generator} />
		<title>{shareTitle}</title>
		<meta property="og:site_name" content="Laughing Skull Entertainment" />
		<meta property="og:type" content="article" />
		<meta property="og:title" content={shareTitle} />
		<meta property="og:description" content={shareDescription} />
		<meta property="og:url" content={shareUrl} />
		<meta property="og:image" content={shareImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={shareTitle} />
		<meta name="twitter:description" content={shareDescription} />
		<meta name="twitter:image" content={shareImageUrl} />
		<style is:global>
			html,
			body {
				margin: 0;
				padding: 0;
			}

			body {
				background: #05070d;
			}
		</style>
	</head>
	<body>
		<HomepageClientMount content={homepageContent} client:only="react" />
	</body>
</html>