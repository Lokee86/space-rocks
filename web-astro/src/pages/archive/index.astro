---
import { getCollection } from "astro:content";
import ArchiveClientMount from "../../components/ArchiveClientMount";
import "../../components/plasmic/plasmic__default_style.css";
import "../../components/plasmic/space_rocks_devlog/plasmic.css";

const devlogEntries = await getCollection("devlog");
const entries = devlogEntries
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
	.map((entry) => ({
		id: entry.id,
		title: entry.data.title,
		date: entry.data.date.toISOString().slice(0, 10),
		summary: entry.data.summary,
		href: `/devlog/${entry.id}/`,
	}));

const archiveContent = { entries };

const shareImageUrl = new URL("/assets/ui/thumbnail.png", Astro.site).toString();
const shareUrl = new URL("/archive/", Astro.site).toString();
const shareTitle = "Space Rocks Devlog Archive";
const shareDescription = "All development posts for Space Rocks.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/assets/ui/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={shareDescription} />
		<meta name="theme-color" content="#00e5ff" />
		<title>{shareTitle}</title>
		<meta property="og:site_name" content="Laughing Skull Entertainment" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={shareTitle} />
		<meta property="og:description" content={shareDescription} />
		<meta property="og:url" content={shareUrl} />
		<meta property="og:image" content={shareImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={shareTitle} />
		<meta name="twitter:description" content={shareDescription} />
		<meta name="twitter:image" content={shareImageUrl} />
		<style is:global>
			html,
			body {
				margin: 0;
				padding: 0;
			}

			body {
				background: #05070d;
			}
		</style>
	</head>
	<body>
		<ArchiveClientMount content={archiveContent} client:only="react" />
	</body>
</html>